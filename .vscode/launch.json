{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI: Run API Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["src.main:app", "--reload", "--host", "0.0.0.0", "--port", "8080"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/api",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/apps/api;${workspaceFolder}",
        "APP_ENV": "local"
      }
    },
    {
      "name": "Run main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/apps/api/src/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/api",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/apps/api;${workspaceFolder}",
        "APP_ENV": "local"
      }
    }
  ]
}
