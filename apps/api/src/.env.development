# Configuration file for Job Matching System

SPEC_COLLECTION = "job_specialties"
ALIAS_COLLECTION = "job_aliases"

# Search Index Names
SPEC_VECTOR_INDEX = "spec_vector_index"
SPEC_FULLTEXT_INDEX = "spec_fulltext_index"
ALIAS_VECTOR_INDEX = "alias_vector_index"
ALIAS_FULLTEXT_INDEX = "alias_fulltext_index"

# Embedding Configuration
# Using sentence-transformers with the BGE model you have in your model folder
EMBEDDING_MODEL = "BAAI/bge-large-en-v1.5"  # Or use your local model path
