# Reranker Configuration
RERANKER_MODEL = "BAAI/bge-reranker-large"  # Or use your local model path

# Search Configuration
TOP_K_PER_SEARCH = 20  # Top 20 from each search
TOTAL_CANDIDATES_SPEC = 3000  # Number of candidates for vector search
TOTAL_CANDIDATES_ALIAS = 10000
FINAL_RESULTS_LIMIT = 5  # Final top results to return

# Hybrid Search Weights
VECTOR_WEIGHT = 0.5
FULLTEXT_WEIGHT = 0.5

# Input File Configuration
INPUT_EXCEL_FILE = "MJL_custom.xlsx"  # Path to your Excel file