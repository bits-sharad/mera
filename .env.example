DOC_PROCESSING_API_KEY=your-api-key-here

# Option 1: Use direct auth token
AUTH_TOKEN=your-bearer-token-here

# Option 2: Or fetch token via client credentials
# FETCH_TOKEN_USERNAME=your-client-id
# FETCH_TOKEN_PASSWORD=your-client-secret

# Optional: override API URLs
# AUTH_URL=https://your-auth-url/oauth2/token
# DOC_PROCESSING_API_BASE_URL=https://your-doc-api-url/v1
